# Invoice SaaS — environment template
#
# Copy to `.env` and fill in. `.env` is gitignored; `.env.example` is committed
# as documentation of every variable the app reads. All values are OPTIONAL for
# local dev — the app falls back to safe no-credential modes so it runs end-to-end
# without any of these set (see the provider-seam factories in packages/db and
# packages/worker).

# ---------------------------------------------------------------------------
# Database (Prisma / Postgres)
# ---------------------------------------------------------------------------
# Used by `prisma generate`, `prisma validate`, `prisma db push`, and at runtime.
# A placeholder is enough for `prisma validate`/generate; a real Postgres is
# required to run the test suites and the API/worker.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/invoicesaas?schema=public"

# ---------------------------------------------------------------------------
# Stripe (T3 — payment link + webhook)
# ---------------------------------------------------------------------------
# Both unset  -> createPaymentProvider() returns the FakePaymentProvider.
#                Tests pass with NO Stripe account. Payment links look like
#                https://pay.test/invoice/{invoiceId}.
# Both set    -> creates the real StripePaymentProvider (fetch-based, no SDK).
#
# Secret key for the REST API (creating Payment Links). From Stripe Dashboard
# -> Developers -> API keys (test mode: sk_test_...).
STRIPE_SECRET_KEY=""
# Webhook signing secret for verifying incoming webhook signatures. From
# Stripe Dashboard -> Developers -> Webhooks -> [your endpoint] -> Signing secret
# (whsec_...). Required for the real verifyWebhookSignature path to run; the
# unit test for it is guarded by this var so it never fails when unset.
STRIPE_WEBHOOK_SECRET=""

# ---------------------------------------------------------------------------
# Email (T2 / T4 — invoice + reminder emails)
# ---------------------------------------------------------------------------
# Unset  -> createEmailSender() returns the ConsoleEmailSender (logs instead of
#           sending). Good for local dev.
# Set    -> sends via Resend (no SDK; uses fetch).
RESEND_API_KEY=""
# From address used by the Resend sender. Falls back to invoices@acme.test.
RESEND_FROM="invoices@yourdomain.test"

# ---------------------------------------------------------------------------
# Alerting (C5 — failure alerts from the worker schedulers)
# ---------------------------------------------------------------------------
# Unset  -> alerts are console-only ([ALERT] … on stderr).
# Set    -> the worker also emails this address (through the same EmailSender as
#           invoices) when a recurring/reconciliation sweep throws, or when a
#           recurring invoice is HELD by the verification gate. A failed alert
#           email is logged, never fatal — alerting can't crash the scheduler.
ALERT_EMAIL=""

# ---------------------------------------------------------------------------
# Admin API (T4 — POST /admin/run-overdue overdue-sweep trigger)
# ---------------------------------------------------------------------------
# REQUIRED for the admin route to accept any request. Set to a long random secret.
# Requests must send `Authorization: Bearer <ADMIN_API_TOKEN>`. If this is unset OR
# the token is wrong/missing, the route returns 401 (no open fallback by design).
# Generate e.g. `openssl rand -hex 32`.
ADMIN_API_TOKEN=""

# ---------------------------------------------------------------------------
# Cloudflare Tunnel (deploy "Path B" — see DEPLOY.md)
# ---------------------------------------------------------------------------
# Only needed when deploying via docker-compose.cloudflared.yml (no public IP).
# Create a tunnel in the Cloudflare Zero Trust dashboard (Networks -> Tunnels),
# copy its connector token here, and set the tunnel's Public Hostname to route
# your domain -> service http://web:3000. Leave blank for the nginx/Let's Encrypt
# path. Treat this token like a password.
CLOUDFLARE_TUNNEL_TOKEN=""
