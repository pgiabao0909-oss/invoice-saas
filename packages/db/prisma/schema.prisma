// Invoice SaaS — Prisma schema (hybrid tenancy, ADR 0001)
//
// Row-Level Security (the defense-in-depth backstop) is NOT auto-generated by
// Prisma. Apply the DDL in `src/rls.sql` via a migration so pooled tenants are
// physically isolated by `tenantId` even if app code errs. The app-level guard
// lives in `src/tenancy/scoped.ts`.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TenantDataMode {
  POOLED
  SILOED
}

enum InvoiceStatus {
  draft
  sent
  paid
  overdue
  void
}

enum OutboxType {
  INVOICE_SENT
  PAYMENT_RECEIVED
  INVOICE_OVERDUE
}

enum JobStatus {
  PENDING
  RUNNING
  DONE
  FAILED
}

/// Tenant registry: routes each request to the correct data store (hybrid tenancy).
model Tenant {
  id           String         @id @default(cuid())
  name         String
  slug         String         @unique
  dataMode     TenantDataMode @default(POOLED)
  dataLocation String? // for SILOED tenants: dedicated DB/schema
  baseCurrency String         @default("USD")
  /// Tenant-configurable branding for invoices/emails (T2). Free-form JSON.
  branding      Json?
  createdAt    DateTime       @default(now())

  clients   Client[]
  invoices  Invoice[]
  payments  Payment[]
  taxRates  TaxRate[]
  outbox    OutboxMessage[]
  subscriptions Subscription[]
}

model Client {
  id             String   @id @default(cuid())
  tenantId       String
  legalName      String
  email          String
  billingAddress String?
  taxIdentifier  String?
  createdAt      DateTime @default(now())

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoices Invoice[]
  subscriptions Subscription[]

  @@unique([tenantId, email])
  @@index([tenantId])
}

model TaxRate {
  id          String   @id @default(cuid())
  tenantId    String
  code        String
  jurisdiction String
  rateBps     Int // basis points, e.g. 2000 = 20%
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model Invoice {
  id            String        @id @default(cuid())
  tenantId      String
  clientId      String
  invoiceNumber String
  status        InvoiceStatus @default(draft)
  currency      String
  issueDate     DateTime      @default(now())
  dueDate       DateTime
  lineItems     Json // raw line items (record); computed totals stored below
  discount      Json?
  subtotalMinor Int
  taxMinor      Int
  discountMinor Int
  totalMinor    Int
  amountPaidMinor Int         @default(0)
  /// Stripe-hosted payment link created at send time (T3). Lets clients pay online.
  paymentLink  String?
  /// Idempotency key for the upstream ingest event (guide §C3). Unique so a retried
  /// POST /ingest can never create a duplicate invoice. Null for manually-created invoices.
  idempotencyKey String? @unique
  createdAt     DateTime      @default(now())

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client   Client    @relation(fields: [clientId], references: [id])
  payments Payment[]

  @@unique([tenantId, invoiceNumber])
  @@index([tenantId])
  @@index([tenantId, status])
}

/// Recurring billing schedule (guide §C2). When `anchorDate` passes, the worker
/// generates an invoice and advances `anchorDate` by the interval. `active` can be
/// toggled to pause a schedule without deleting it.
model Subscription {
  id            String   @id @default(cuid())
  tenantId      String
  clientId      String
  currency      String   @default("USD")
  lineItems     Json
  discount      Json?
  /// 'day' | 'week' | 'month' | 'year' — validated by the contract enum.
  intervalUnit  String
  intervalCount Int      @default(1)
  /// Next charge date; the scheduler fires when anchorDate <= now.
  anchorDate    DateTime
  lastRunAt     DateTime?
  active        Boolean  @default(true)
  /// Net terms applied to each generated invoice (days from generation to due).
  netDays       Int      @default(14)
  createdAt     DateTime @default(now())

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, anchorDate])
}

/// Idempotency is enforced by the unique (tenantId, idempotencyKey) — retries are safe.
model Payment {
  id             String   @id @default(cuid())
  invoiceId      String
  tenantId       String
  amountMinor    Int
  currency       String
  idempotencyKey String
  stripeChargeId String?
  createdAt      DateTime @default(now())

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@unique([tenantId, idempotencyKey])
  @@index([tenantId])
}

/// Transactional outbox: written in the same DB tx as the domain change → no dual-write gap.
model OutboxMessage {
  id        String      @id @default(cuid())
  tenantId  String?
  type      OutboxType
  payload   Json
  published Boolean     @default(false)
  createdAt DateTime    @default(now())

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([published])
}

/// Durable job queue consumed by the worker (off the request path).
model Job {
  id          String    @id @default(cuid())
  type        String
  payload     Json
  status      JobStatus @default(PENDING)
  attempts    Int       @default(0)
  /// Retry ceiling: after this many attempts a failing job is parked as FAILED.
  maxAttempts Int       @default(5)
  /// Last failure message, for observability of retried/failed jobs (guide §3.2).
  lastError   String?
  availableAt DateTime  @default(now())
  createdAt   DateTime  @default(now())

  @@index([status, availableAt])
}

/// Immutable, append-only audit trail (guide §2.5). The app never updates or
/// deletes rows here — every state change appends one record, giving a tamper-
/// evident history you can trust without lifting a finger. Not tied to Invoice by
/// FK so a record survives even if an invoice is later removed.
model AuditLog {
  id        String   @id @default(cuid())
  tenantId  String
  invoiceId String?
  event     String
  detail    Json?
  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([tenantId, invoiceId])
}
